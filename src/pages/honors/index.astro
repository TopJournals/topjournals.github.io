---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { honors } from '../../data/honors';
---

<BaseLayout title="Honors | Metastructure Lab">
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro
      eyebrow="Awards and service"
      title="Honors & Awards"
    />
    <div class="divide-y divide-slate-200 border-y border-slate-200">
      {honors.map((honor) => (
        <article class="grid gap-2 py-5 md:grid-cols-[100px_1fr]">
          <p class="font-bold text-academic-blue">{honor.year}</p>
          <div>
            <h2 class="font-bold text-academic-heading">{honor.title}</h2>
            <p class="mt-1 text-slate-600">{honor.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
