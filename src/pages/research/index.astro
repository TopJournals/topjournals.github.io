---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { researchProjects } from '../../data/research';
---

<BaseLayout title="Research | Metastructure Lab">
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro
      title="Researchs"
    />
    <div class="space-y-6">
      {researchProjects.map((project) => <ResearchCard project={project} layout="list" />)}
    </div>
  </section>
</BaseLayout>
