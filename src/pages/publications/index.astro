---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { publicationTags, publicationYears, publications } from '../../data/publications';
import { conferenceActivities } from '../../data/conference';
import { highlightDaweiLi } from '../../utils/highlightName';

const highlightedConference = conferenceActivities.map((item) => ({
  ...item,
  contributorsHtml: highlightDaweiLi(item.contributors)
}));
---

<BaseLayout title="Publications | Metastructure Lab">
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro
      eyebrow="Research output"
      title="Publications"
    />

    <div class="mb-8 grid gap-3 rounded border border-slate-200 bg-slate-50 p-4 md:grid-cols-[1fr_170px_220px]">
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Search</span>
        <input id="publication-search" class="focus-ring w-full rounded border border-slate-300 bg-white px-3 py-2 text-sm" type="search" placeholder="Title, author, venue, tag" />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Year</span>
        <select id="publication-year" class="focus-ring w-full rounded border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="">All years</option>
          {publicationYears.map((year) => <option value={year}>{year}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Tag</span>
        <select id="publication-tag" class="focus-ring w-full rounded border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="">All tags</option>
          {publicationTags.map((tag) => <option value={tag.toLowerCase()}>{tag}</option>)}
        </select>
      </label>
    </div>

    <p id="publication-count" class="mb-3 text-sm font-medium text-slate-500">{publications.length} publications</p>
    <div id="publication-list">
      {publications.map((publication) => <PublicationCard publication={publication} />)}
    </div>
    <p id="publication-empty" class="hidden rounded border border-slate-200 bg-slate-50 p-6 text-slate-600">No publications match the current filters.</p>

    <div id="conference-activities" class="mt-14 space-y-6">
      <article class="hover-card rounded border border-slate-200 bg-slate-50 p-6 shadow-sm">
        <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="text-2xl font-bold text-academic-heading">Conference Papers & Presentations</h2>
          </div>
        </div>
        <div class="space-y-5">
          {highlightedConference.map((item) => (
            <article class="border-b border-slate-200 pb-5 last:border-b-0 last:pb-0">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <span class="rounded bg-white px-2 py-1 text-xs font-semibold text-slate-600">{item.kind}</span>
                <span class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">{item.date}</span>
              </div>
              <h3 class="font-bold leading-snug text-academic-heading">{item.title}</h3>
              <p class="mt-1 text-sm text-slate-600" set:html={item.contributorsHtml} />
              <p class="mt-1 text-sm text-slate-500">{item.venue}, {item.location}</p>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>('#publication-search');
    const yearSelect = document.querySelector<HTMLSelectElement>('#publication-year');
    const tagSelect = document.querySelector<HTMLSelectElement>('#publication-tag');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.publication-card'));
    const count = document.querySelector<HTMLElement>('#publication-count');
    const empty = document.querySelector<HTMLElement>('#publication-empty');

    function applyFilters() {
      if (!searchInput || !yearSelect || !tagSelect || !count || !empty) return;

      const query = searchInput.value.trim().toLowerCase();
      const year = yearSelect.value;
      const tag = tagSelect.value;
      let visible = 0;

      for (const card of cards) {
        const haystack = `${card.dataset.title} ${card.dataset.authors} ${card.textContent}`.toLowerCase();
        const matchesQuery = !query || haystack.includes(query);
        const matchesYear = !year || card.dataset.year === year;
        const matchesTag = !tag || Boolean(card.dataset.tags?.includes(tag));
        const show = matchesQuery && matchesYear && matchesTag;
        card.classList.toggle('hidden', !show);
        if (show) visible += 1;
      }

      count.textContent = `${visible} publication${visible === 1 ? '' : 's'}`;
      empty.classList.toggle('hidden', visible !== 0);
    }

    searchInput?.addEventListener('input', applyFilters);
    yearSelect?.addEventListener('change', applyFilters);
    tagSelect?.addEventListener('change', applyFilters);
  </script>
</BaseLayout>
