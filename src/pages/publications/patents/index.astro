---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionIntro from '../../../components/SectionIntro.astro';
import { patentRecords, standardRecords } from '../../../data/intellectualProperty';
import { highlightDaweiLi } from '../../../utils/highlightName';

const highlightedPatents = patentRecords.map((item) => ({
  ...item,
  inventorsHtml: highlightDaweiLi(item.inventors)
}));
---

<BaseLayout title="Patents | Metastructure Lab">
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro eyebrow="Publications" title="Patents" />

    <div class="space-y-6">
      {highlightedPatents.map((item) => (
        <article class="hover-card rounded border border-slate-200 bg-white p-6 shadow-sm">
          <div class="mb-3 flex flex-wrap items-center gap-3">
            <span class="rounded bg-blue-50 px-2 py-1 text-xs font-semibold text-academic-blue">{item.year}</span>
            <span class="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600">{item.type}</span>
          </div>
          <h2 class="text-xl font-bold leading-snug text-academic-heading">{item.title}</h2>
          <p class="mt-3 text-sm text-slate-600" set:html={item.inventorsHtml} />
        </article>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="section-heading">Standards</h2>
      <div class="space-y-4">
        {standardRecords.map((item) => (
          <article class="hover-card rounded border border-slate-200 bg-slate-50 p-5 shadow-sm">
            <div class="mb-2 flex flex-wrap items-center gap-3">
              <span class="rounded bg-white px-2 py-1 text-xs font-semibold text-slate-600">{item.year}</span>
              <span class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">{item.code}</span>
            </div>
            <h3 class="font-bold text-academic-heading">{item.title}</h3>
            <p class="mt-1 text-sm text-slate-600">{item.authority}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
