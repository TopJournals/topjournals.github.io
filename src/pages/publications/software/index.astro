---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionIntro from '../../../components/SectionIntro.astro';
import { softwareRecords } from '../../../data/intellectualProperty';
import { highlightDaweiLi } from '../../../utils/highlightName';

const highlightedSoftware = softwareRecords.map((item) => ({
  ...item,
  holdersHtml: highlightDaweiLi(item.holders)
}));
---

<BaseLayout title="Software | Metastructure Lab">
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro eyebrow="Publications" title="Software Copyrights" />

    <div class="space-y-6">
      {highlightedSoftware.map((item) => (
        <article class="hover-card rounded border border-slate-200 bg-white p-6 shadow-sm">
          <div class="mb-3 flex flex-wrap items-center gap-3">
            <span class="rounded bg-blue-50 px-2 py-1 text-xs font-semibold text-academic-blue">{item.year}</span>
            <span class="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600">Software Copyright</span>
          </div>
          <h2 class="text-xl font-bold leading-snug text-academic-heading">{item.title}</h2>
          <p class="mt-3 text-sm text-slate-600" set:html={item.holdersHtml} />
          <p class="mt-1 text-sm text-slate-500">{item.authority}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
