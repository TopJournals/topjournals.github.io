---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { people } from '../../data/people';
import { biography, professionalActivities, site } from '../../data/site';
import { highlightDaweiLi } from '../../utils/highlightName';

const highlightedLeader = highlightDaweiLi(site.leader);
const highlightedBiography = biography.map((paragraph) => highlightDaweiLi(paragraph));
const highlightedActivities = professionalActivities.map((activity) => highlightDaweiLi(activity));
---

<BaseLayout title="People | Metastructure Lab">
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionIntro
      eyebrow="Team"
      title="People"
    />
    <article class="hover-card mb-8 rounded border border-slate-200 bg-slate-50 p-6 shadow-sm">
      <div class="flex items-start gap-4">
        <img
          src={site.leaderAvatar}
          alt={`${site.leader} avatar`}
          class="w-24 h-32 shrink-0 rounded border border-slate-200 bg-slate-50 object-cover"
        />
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-academic-blue">Principal Investigator</p>
          <h2 class="mt-2 text-2xl font-bold text-academic-heading"><span set:html={highlightedLeader} /> <span class="text-slate-400">{site.leaderChinese}</span></h2>
          <p class="mt-2 text-slate-600">{site.affiliation}</p>
          <a href={`mailto:${site.email}`} class="mt-3 inline-flex text-sm font-semibold text-academic-blue hover:underline">{site.email}</a>
        </div>
      </div>
    </article>
    <div class="mb-10 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="hover-card rounded border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-academic-heading">Biography</h2>
        <div class="mt-4 space-y-4">
          {highlightedBiography.map((paragraph) => (
            <p class="text-slate-600" set:html={paragraph} />
          ))}
        </div>
      </article>
      <article class="hover-card rounded border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-academic-heading">Professional Activities</h2>
        <div class="mt-4 space-y-4">
          {highlightedActivities.map((activity) => (
            <p class="text-slate-600" set:html={activity} />
          ))}
        </div>
      </article>
    </div>
    <h2 class="mb-4 text-xl font-bold text-academic-heading">Students and Researchers</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {people.map((person) => (
        <article class="hover-card flex items-start gap-4 rounded border border-slate-200 bg-white p-5 shadow-sm">
          <img
            src={person.avatar}
            alt={`${person.name} cartoon cat avatar`}
            class="h-16 w-16 shrink-0 rounded-full border border-slate-200 bg-slate-50 object-cover shadow-sm"
            loading="lazy"
          />
          <div class="min-w-0 pt-1">
            <h2 class="font-bold text-academic-heading">{person.name}</h2>
            <p class="mt-1 text-sm text-slate-600">{person.role}</p>
            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">Since {person.start}</p>
            {(person.scholarUrl || person.researchGateUrl) && (
              <div class="mt-3 flex items-center gap-3">
                {person.scholarUrl && (
                  <a
                    href={person.scholarUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-academic-blue hover:underline flex items-center gap-1"
                    title="Google Scholar"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 22.4c-5.745 0-10.4-4.655-10.4-10.4S6.255 1.6 12 1.6 22.4 6.255 22.4 12 17.745 22.4 12 22.4z"/>
                      <path d="M10.95 14.75c.75 1.25 2.25 1.5 3.5.75.75-.5 1.25-1.25 1.25-2.25 0-1.5-1.25-2.5-2.75-2.5-1.5 0-2.75 1-2.75 2.5 0 .5.25 1 .75 1.5zm-1.5-4c0-1.5 1.25-2.5 2.75-2.5 1.5 0 2.75 1 2.75 2.5 0 1-1.25 2-2.75 2-1.5 0-2.75-1-2.75-2z"/>
                    </svg>
                    Scholar
                  </a>
                )}
                {person.researchGateUrl && (
                  <a
                    href={person.researchGateUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-academic-blue hover:underline flex items-center gap-1"
                    title="ResearchGate"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                    </svg>
                    ResearchGate
                  </a>
                )}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
