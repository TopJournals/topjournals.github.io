---
import '../styles/global.css';
import { site } from '../data/site';

type Props = {
  title?: string;
  description?: string;
};

type NavChild = {
  href: string;
  label: string;
};

type NavItem = {
  href: string;
  label: string;
  children?: NavChild[];
};

type MobileNavItem = {
  href: string;
  label: string;
  mobileChild?: boolean;
};

const { title = site.title, description = site.description } = Astro.props;
const navItems: NavItem[] = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  {
    href: '/publications/',
    label: 'Publications',
    children: [
      { href: '/publications/', label: 'Papers' },
      { href: '/publications/patents/', label: 'Patents' },
      { href: '/publications/software/', label: 'Software' }
    ]
  },
  { href: '/resources/', label: 'Resources' },
  { href: '/people/', label: 'People' },
  { href: '/news/', label: 'News' }
];
const mobileNavItems: MobileNavItem[] = navItems.flatMap((item) =>
  item.children
    ? [{ href: item.href, label: item.label }, ...item.children.map((child) => ({ ...child, mobileChild: true }))]
    : [{ href: item.href, label: item.label }]
);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/original/site/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <nav class="academic-nav fixed left-0 top-0 z-50 w-full">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="focus-ring flex items-center gap-2 rounded">
          <img src="/assets/original/site/favicon.ico" alt="" class="h-7 w-7 object-contain" />
          <span class="text-lg font-bold tracking-tight text-academic-heading">Metastructure Lab</span>
        </a>
        <div class="hidden items-center gap-7 md:flex">
          {navItems.map((item) => (
            item.children ? (
              <div class="nav-group relative">
                <a
                  href={item.href}
                  class="focus-ring inline-flex items-center gap-1 rounded text-sm font-medium text-slate-600 transition-colors hover:text-academic-blue"
                >
                  {item.label}
                  <svg viewBox="0 0 20 20" aria-hidden="true" class="h-4 w-4">
                    <path d="M5.5 7.5 10 12l4.5-4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
                  </svg>
                </a>
                <div class="nav-dropdown absolute left-0 top-full min-w-[180px] pt-3">
                  <div class="rounded-lg border border-slate-200 bg-white p-2 shadow-lg">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="focus-ring block rounded-md px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-academic-blue"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="focus-ring rounded text-sm font-medium text-slate-600 transition-colors hover:text-academic-blue"
              >
                {item.label}
              </a>
            )
          ))}
        </div>
      </div>
      <div class="flex gap-5 overflow-x-auto border-t border-slate-100 px-4 py-2 md:hidden">
        {mobileNavItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'whitespace-nowrap text-sm font-medium text-slate-600',
              item.mobileChild ? 'pl-2 text-slate-500' : ''
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <main class="pt-24 md:pt-16">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 py-8">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 text-sm text-slate-500 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
        <div>
          <strong class="text-slate-700">{site.name}</strong><br />
          {site.affiliation}
        </div>
        <div class="flex flex-wrap gap-4">
          <a href={`mailto:${site.email}`} class="hover:text-academic-blue">{site.email}</a>
          <a href="/honors/" class="hover:text-academic-blue">Honors</a>
          <a href={site.scholarUrl} target="_blank" rel="noreferrer" class="hover:text-academic-blue">Google Scholar</a>
        </div>
      </div>
    </footer>
  </body>
</html>
