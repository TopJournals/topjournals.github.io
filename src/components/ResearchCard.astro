---
import type { ResearchProject } from '../data/research';

type Props = {
  project: ResearchProject;
  layout?: 'grid' | 'list';
};

const { project, layout = 'grid' } = Astro.props;
---

{
  layout === 'list' ? (
    <article class="hover-card overflow-hidden rounded border border-slate-200 bg-white shadow-sm">
      <div class="grid gap-0 md:grid-cols-[320px_1fr]">
        <div class="flex items-center justify-center bg-slate-50 p-4">
          <img src={project.image} alt={project.title} class="block h-auto w-full object-contain" loading="lazy" />
        </div>
        <div class="p-6">
          <h2 class="text-xl font-bold leading-snug text-academic-heading">{project.title}</h2>
          <p class="mt-4 text-sm leading-7 text-slate-600">{project.summary}</p>
          {project.paperUrl && (
            <a href={project.paperUrl} target="_blank" rel="noreferrer" class="mt-4 inline-flex text-sm font-semibold text-academic-blue hover:underline">
              {project.paperLabel ?? project.paperUrl}
            </a>
          )}
        </div>
      </div>
    </article>
  ) : (
    <article class="hover-card overflow-hidden rounded border border-slate-200 bg-white shadow-sm">
      <div class="flex aspect-video items-center justify-center bg-slate-50 p-4">
        <img src={project.image} alt={project.title} class="block h-full w-full object-contain" loading="lazy" />
      </div>
      <div class="p-5">
        <div class="mb-3 flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600">{tag}</span>
          ))}
        </div>
        <h2 class="text-lg font-bold leading-snug text-academic-heading">{project.title}</h2>
        <p class="mt-3 text-sm text-slate-600">{project.summary}</p>
        {project.paperUrl && (
          <a href={project.paperUrl} target="_blank" rel="noreferrer" class="mt-4 inline-flex text-sm font-semibold text-academic-blue hover:underline">
            {project.paperLabel ?? project.paperUrl}
          </a>
        )}
      </div>
    </article>
  )
}
