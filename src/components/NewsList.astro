---
import type { NewsItem } from '../data/news';
import { highlightDaweiLi } from '../utils/highlightName';

type Props = {
  items: NewsItem[];
};

const { items } = Astro.props;
const monthLabels = ['Jan.', 'Feb.', 'Mar.', 'Apr.', 'May.', 'Jun.', 'Jul.', 'Aug.', 'Sept.', 'Oct.', 'Nov.', 'Dec.'];
const formatNewsDate = (date: string) => {
  const match = date.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!match) return date;

  const [, year, month, day] = match;
  return `${monthLabels[Number(month) - 1]} ${Number(day)}, ${year}`;
};
---

<div class="divide-y divide-slate-200 border-y border-slate-200">
  {items.map((item) => (
    <article class="grid gap-2 py-4 md:grid-cols-[120px_1fr]">
      <time datetime={item.date} class="text-sm font-semibold text-slate-500">{formatNewsDate(item.date)}</time>
      <p class={item.highlight ? 'font-medium text-academic-heading' : 'text-slate-600'} set:html={highlightDaweiLi(item.text)} />
    </article>
  ))}
</div>
