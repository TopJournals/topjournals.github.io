---
import type { Publication } from '../data/publications';
import { highlightDaweiLi } from '../utils/highlightName';

type Props = {
  publication: Publication;
};

const { publication } = Astro.props;
const highlightedAuthors = highlightDaweiLi(publication.authors);
---

<article
  class="publication-card rounded-lg border-b border-slate-200 py-6 transition-transform duration-200 hover:translate-x-1"
  data-title={publication.title.toLowerCase()}
  data-authors={publication.authors.toLowerCase()}
  data-year={publication.year}
  data-tags={publication.tags.join('|').toLowerCase()}
>
  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
    <div>
      <div class="mb-2 flex flex-wrap items-center gap-2">
        <span class="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-600">{publication.year}</span>
        {publication.featured && <span class="rounded bg-blue-50 px-2 py-1 text-xs font-semibold text-academic-blue">Featured</span>}
        {publication.highlyCited && <span class="rounded bg-slate-900 px-2 py-1 text-xs font-semibold text-white">Highly cited</span>}
        {publication.status && <span class="rounded bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700">{publication.status}</span>}
      </div>
      <h2 class="text-lg font-bold leading-snug text-academic-heading">{publication.title}</h2>
      <p class="mt-2 text-sm text-slate-600" set:html={highlightedAuthors} />
      <p class="mt-1 text-sm font-medium text-slate-700">{publication.venue}</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {publication.tags.map((tag) => (
          <span class="rounded-full border border-slate-200 px-2.5 py-1 text-xs text-slate-600">{tag}</span>
        ))}
      </div>
    </div>
    {publication.paperUrl && (
      <a
        href={publication.paperUrl}
        target="_blank"
        rel="noreferrer"
        class="focus-ring inline-flex shrink-0 items-center justify-center rounded bg-academic-blue px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-800"
      >
        Paper
      </a>
    )}
  </div>
</article>
